NODE_ENV=production
PORT=3000
HOST=127.0.0.1
PUBLIC_BASE_URL=https://hoo66.top

# Generate with: openssl rand -hex 32
TOKEN_SECRET=replace-with-a-long-random-secret

# Keep xu/si stable forever. Current production startup requires both entries on every boot.
# Existing accounts are not automatically updated from later display-name/password edits here.
COUPLECHAT_ACCOUNTS=xu|小旭|replace-xu-password|🐶;si|小偲|replace-si-password|🐰

APP_DEEP_LINK_SCHEME=couplechat://
PUSH_ENABLED=true
# 可选：覆盖内置的 CoupleChat Bark 通知图标公网地址。
#BARK_ICON_URL=https://example.com/custom-icon.png

# PostgreSQL（生产必须设置）
DATABASE_URL=postgres://couplechat:replace-with-strong-password@localhost:5432/couplechat
# Web 容器只校验 schema；发布时单独执行 `npm run migrate`。
RUN_MIGRATIONS=false

# ── AI（大橘）：不配置则 ai 频道走本地兜底 ──
# OpenAI 兼容口填到 /v1。Responses 模式支持原生识图、联网工具和 reasoning effort。
#AI_BASE_URL=https://api.aijws.com/v1
#AI_API_KEY=sk-xxx
#AI_MODEL=gpt-5.6-luna
#AI_API_MODE=responses
#AI_REASONING_EFFORT=high
# 对话、记忆提取、滚动摘要和后台整理均使用 high。
#AI_TASK_REASONING_EFFORT=high
# 也可用其他 AI_CHAT_* / AI_TASK_* 变量分别覆盖模型、接口或密钥。
#AI_TRIGGER_ALIASES=@大橘
# 图片理解：与对话同一主模型多模态（本条图或回看最近图组 + 问题一起送入），无独立 AI_VISION。

# ── 语音转写（可选；不配置时语音照常发送，转写状态为 unavailable）──
# OpenAI-compatible audio/transcriptions；后台 worker 受 SCHEDULED_JOBS_ENABLED 控制。
#TRANSCRIPTION_PROVIDER=openai-compatible
#TRANSCRIPTION_BASE_URL=https://api.openai.com/v1
#TRANSCRIPTION_API_KEY=sk-xxx
#TRANSCRIPTION_MODEL=whisper-1
#TRANSCRIPTION_LANGUAGE=zh
#TRANSCRIPTION_TIMEOUT_MS=120000
#TRANSCRIPTION_POLL_INTERVAL_MS=10000

# 阿里云百炼 Qwen3-ASR（适合聊天短语音；使用兼容模式的 chat/completions）
#TRANSCRIPTION_PROVIDER=dashscope-qwen
#TRANSCRIPTION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#TRANSCRIPTION_API_KEY=sk-xxx
#TRANSCRIPTION_MODEL=qwen3-asr-flash
#TRANSCRIPTION_LANGUAGE=zh

# ── 向量检索（可选，不配则召回退化为高重要度事实兜底）──
# 单 key 写法（兼容旧格式）：
#EMBEDDING_BASE_URL=https://api.voyageai.com/v1
#EMBEDDING_API_KEY=pa-xxx
#EMBEDDING_MODEL=voyage-3.5-lite
#EMBEDDING_DIM=1024

# 多账号池写法（推荐，key 逗号分隔，同一 provider 内失败自动换下一个 key，
# provider 之间也会顺序 failover；配了这个就不用管上面单 key 的写法）：
#EMBEDDING_MODEL=voyage-4
#EMBEDDING_DIM=1024
#EMBEDDING_VOYAGE_PROVIDER=voyage
#EMBEDDING_VOYAGE_BASE_URL=https://api.voyageai.com/v1
#EMBEDDING_VOYAGE_API_KEYS=pa-key1,pa-key2,pa-key3
#EMBEDDING_MONGODB_PROVIDER=mongodb-voyage
#EMBEDDING_MONGODB_BASE_URL=https://ai.mongodb.com/v1
#EMBEDDING_MONGODB_API_KEYS=al-key1,al-key2

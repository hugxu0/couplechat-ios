NODE_ENV=production
PORT=8080
HOST=127.0.0.1
PUBLIC_BASE_URL=https://hoo66.top

# Generate with: openssl rand -hex 32
TOKEN_SECRET=replace-with-a-long-random-secret

# Keep xu/si stable forever. Change only passwords and display names if needed.
# After first successful boot, you may remove this line from the server .env.
COUPLECHAT_ACCOUNTS=xu|小旭|replace-xu-password|🐶;si|小偲|replace-si-password|🐰

APP_DEEP_LINK_SCHEME=couplechat://

# PostgreSQL（生产必须设置）
DATABASE_URL=postgres://couplechat:replace-with-strong-password@localhost:5432/couplechat

# ── AI（大橘）：不配置则 ai 频道走本地兜底 ──
# OpenAI 兼容口填到 /v1；模型名 claude- 开头时自动走 Anthropic 原生协议。
#AI_BASE_URL=https://api.deepseek.com/v1
#AI_API_KEY=sk-xxx
#AI_MODEL=deepseek-chat
# 可分别覆盖：AI_CHAT_*（对话，要快）/ AI_TASK_*（后台整理，要稳）
#AI_TRIGGER_ALIASES=@大橘

# ── 识图 + 联网（可选，通常与 AI_VISION 共用 MiMo 账号）──
# ai 私聊每条图片都识图；couple 频道靠意图判断按需识图。
#AI_VISION_BASE_URL=https://api.xiaomimimo.com/v1
#AI_VISION_API_KEY=sk-xxx
#AI_VISION_MODEL=mimo-v2.5

# ── 向量检索（可选，不配则召回退化为高重要度事实兜底）──
# 单 key 写法（兼容旧格式）：
#EMBEDDING_BASE_URL=https://api.voyageai.com/v1
#EMBEDDING_API_KEY=pa-xxx
#EMBEDDING_MODEL=voyage-3.5-lite
#EMBEDDING_DIM=1024

# 多账号池写法（推荐，key 逗号分隔，同一 provider 内失败自动换下一个 key，
# provider 之间也会顺序 failover；配了这个就不用管上面单 key 的写法）：
#EMBEDDING_MODEL=voyage-4
#EMBEDDING_DIM=1024
#EMBEDDING_VOYAGE_PROVIDER=voyage
#EMBEDDING_VOYAGE_BASE_URL=https://api.voyageai.com/v1
#EMBEDDING_VOYAGE_API_KEYS=pa-key1,pa-key2,pa-key3
#EMBEDDING_MONGODB_PROVIDER=mongodb-voyage
#EMBEDDING_MONGODB_BASE_URL=https://ai.mongodb.com/v1
#EMBEDDING_MONGODB_API_KEYS=al-key1,al-key2

NODE_ENV=production
PORT=8080
HOST=127.0.0.1
PUBLIC_BASE_URL=https://hoo66.top

# Generate with: openssl rand -hex 32
TOKEN_SECRET=replace-with-a-long-random-secret

# Keep xu/si stable forever. Change only passwords and display names if needed.
# After first successful boot, you may remove this line from the server .env.
COUPLECHAT_ACCOUNTS=xu|小旭|replace-xu-password|🐶;si|小偲|replace-si-password|🐰

APP_DEEP_LINK_SCHEME=couplechat://

# ── AI（大橘）：不配置则 ai 频道走本地兜底 ──
# OpenAI 兼容口填到 /v1；模型名 claude- 开头时自动走 Anthropic 原生协议。
#AI_BASE_URL=https://api.deepseek.com/v1
#AI_API_KEY=sk-xxx
#AI_MODEL=deepseek-chat
# 可分别覆盖：AI_CHAT_*（对话，要快）/ AI_TASK_*（后台整理，要稳）
#AI_TRIGGER_ALIASES=@大橘

# ── 向量检索（可选，不配则召回退化为高重要度事实兜底）──
#EMBEDDING_BASE_URL=https://api.voyageai.com/v1
#EMBEDDING_API_KEY=pa-xxx
#EMBEDDING_MODEL=voyage-3.5-lite
#EMBEDDING_DIM=1024

{
  "name": "couplechat-server",
  "version": "0.1.0",
  "private": true,
  "description": "Sustainable backend for CoupleChat native clients.",
  "main": "dist/server.js",
  "scripts": {
    "dev:cloud-db": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-cloud-db.ps1",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke:postgres": "tsx scripts/smoke-postgres.ts",
    "test": "npm run typecheck && npm run smoke:postgres",
    "healthcheck": "node scripts/healthcheck.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/multipart": "^9.0.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/agents": "^0.13.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.3.2",
    "nanoid": "^5.1.5",
    "pg": "^8.22.0",
    "socket.io": "^4.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/pg": "^8.20.0",
    "embedded-postgres": "^18.4.0-beta.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}

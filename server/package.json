{
  "name": "couplechat-server",
  "version": "0.1.0",
  "private": true,
  "description": "Sustainable backend for CoupleChat native clients.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "healthcheck": "node scripts/healthcheck.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^9.1.3",
    "dotenv": "^16.4.7",
    "fastify": "^5.3.2",
    "nanoid": "^5.1.5",
    "socket.io": "^4.8.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}

NODE_ENV=development
PORT=8080
HOST=0.0.0.0
PUBLIC_BASE_URL=http://localhost:8080

# Production must set a long random value.
TOKEN_SECRET=change-me-before-production

# username|displayName|password|avatar;username|displayName|password|avatar
# In production, set real passwords here for first boot, then remove the plaintext after accounts are seeded.
COUPLECHAT_ACCOUNTS=xu|小旭|dev-xu-password|🐶;si|小偲|dev-si-password|🐰

# Optional. iOS URL scheme used in Bark push URLs.
APP_DEEP_LINK_SCHEME=couplechat://

NODE_ENV=development
PORT=8080
HOST=0.0.0.0
PUBLIC_BASE_URL=http://localhost:8080

# Production must set a long random value.
TOKEN_SECRET=change-me-before-production

# username|displayName|password|avatar;username|displayName|password|avatar
# In production, set real passwords here for first boot, then remove the plaintext after accounts are seeded.
COUPLECHAT_ACCOUNTS=xu|小旭|dev-xu-password|🐶;si|小偲|dev-si-password|🐰

# Optional. iOS URL scheme used in Bark push URLs.
APP_DEEP_LINK_SCHEME=couplechat://

# PostgreSQL（生产必须设置；本地默认 postgres://couplechat:couplechat@localhost:5432/couplechat）
#DATABASE_URL=postgres://couplechat:password@localhost:5432/couplechat

# ── AI（大橘）────────────────────────────────────────────────
# 不配置时 ai 频道走本地兜底回复，couple 频道不插话。
# 只配 AI_* 时对话和后台任务共用同一个模型；
# AI_CHAT_* / AI_TASK_* 可分别覆盖（chat=用户对话要快，task=后台整理要稳）。
# baseUrl 规则：OpenAI 兼容口填到 /v1（自动拼 /chat/completions）；
# 模型名以 claude- 开头时走 Anthropic 原生协议（自动拼 /messages）。
#AI_BASE_URL=https://api.deepseek.com/v1
#AI_API_KEY=sk-xxx
#AI_MODEL=deepseek-chat
#AI_CHAT_MODEL=deepseek-chat
#AI_TASK_MODEL=deepseek-chat

# couple 频道召唤词（逗号分隔多个别名）；ai 私聊每条都答，无需召唤。
#AI_TRIGGER_ALIASES=@大橘

# ── 向量检索（可选）──────────────────────────────────────────
# 不配置时记忆召回退化为「高重要度事实兜底」，聊天照常。
# OpenAI 兼容 /embeddings 口（Voyage / OpenAI / 硅基流动均可）。
#EMBEDDING_BASE_URL=https://api.voyageai.com/v1
#EMBEDDING_API_KEY=pa-xxx
#EMBEDDING_MODEL=voyage-3.5-lite
#EMBEDDING_DIM=1024
# 召回阈值（可选微调）
#EMBEDDING_FACT_MIN_SCORE=0.45
#EMBEDDING_EPISODE_MIN_SCORE=0.4
